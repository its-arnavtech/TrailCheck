generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Park {
  id          Int                  @id @default(autoincrement())
  name        String
  state       String
  slug        String               @unique
  createdAt   DateTime             @default(now())
  trails      Trail[]
  preferences UserParkPreference[]
}

model Trail {
  id          Int           @id @default(autoincrement())
  parkId      Int
  name        String
  slug        String        @unique
  lengthMiles Float?
  difficulty  Difficulty?
  status      TrailStatus   @default(OPEN)
  description String?
  hazards     Hazard[]
  park        Park          @relation(fields: [parkId], references: [id])
  reports     TrailReport[]
}

model Hazard {
  id          Int            @id @default(autoincrement())
  trailId     Int
  type        HazardType
  severity    HazardSeverity
  title       String
  description String?
  isActive    Boolean        @default(true)
  source      HazardSource   @default(USER)
  externalId  String?
  reportedAt  DateTime       @default(now())
  trail       Trail          @relation(fields: [trailId], references: [id])
}

model TrailReport {
  id               Int      @id @default(autoincrement())
  trailId          Int
  conditionRating  Int
  surfaceCondition String
  note             String?
  reporterName     String?
  createdAt        DateTime @default(now())
  trail            Trail    @relation(fields: [trailId], references: [id])
}

model User {
  id          Int                  @id @default(autoincrement())
  email       String               @unique
  password    String
  gender      Gender               @default(OTHER)
  age         Int                  @default(18)
  createdAt   DateTime             @default(now())
  preferences UserParkPreference[]
}

model UserParkPreference {
  id         Int      @id @default(autoincrement())
  userId     Int
  parkId     Int
  isFavorite Boolean  @default(false)
  wantsToGo  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  park       Park     @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, parkId])
  @@index([userId])
  @@index([parkId])
}

enum TrailStatus {
  OPEN
  CAUTION
  CLOSED
}

enum Difficulty {
  EASY
  MODERATE
  HARD
}

enum HazardType {
  SNOW
  ROCKFALL
  FLOODING
  MUD
  ICE
  CLOSURE
}

enum HazardSeverity {
  LOW
  MEDIUM
  HIGH
}

enum HazardSource {
  USER
  NPS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
